PORT=5000
FRONTEND_URL=http://localhost:3000

# Cloudinary — file storage for processed uploads (PDF, image, video, audio)
# Recommended: separate values (works with special characters in API secret)
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET

# Alternative: single URL (URL-encode special chars in secret, e.g. leading - as %2D)
# CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME

# Optional: enables OpenAI-powered paraphrasing and AI content generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
