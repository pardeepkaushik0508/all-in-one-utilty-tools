PORT=5000
FRONTEND_URL=http://localhost:3000
# Production (Railway): https://aio-tools-frontend-production.up.railway.app

# Cloudinary — REQUIRED on Railway (local disk is ephemeral)
# Use separate values (recommended — works when API secret starts with - or other special chars)
CLOUDINARY_CLOUD_NAME=dqwozzjb7
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Do NOT use placeholder values like <your_api_key> in CLOUDINARY_URL — uploads will fail.
# If using CLOUDINARY_URL instead, URL-encode special chars in secret (leading - as %2D)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@dqwozzjb7

# Google Gemini — AI content generator (text + image). Get key: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: OpenAI fallback for paraphrasing when Gemini is not set
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
