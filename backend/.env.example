PORT=5000
FRONTEND_URL=http://localhost:3000
# Production (Railway/Render): set to your frontend URL

# PostgreSQL — required for CMS/blog/content storage
#
# Render provides two URLs:
#   EXTERNAL — use locally (hostname ends in .render.com)
#   INTERNAL — use on Render backend only (short hostname, same network)
#
# Local example:
# DATABASE_URL=postgresql://user:pass@dpg-xxx.virginia-postgres.render.com/dbname
#
# Render backend service: set DATABASE_URL to the Internal Database URL in Variables.
# Append ?sslmode=require for Render Postgres (both external and internal URLs).
DATABASE_URL=postgresql://user:password@localhost:5432/utilitytools?sslmode=require

# Cloudinary — REQUIRED on Railway (local disk is ephemeral)
#
# Railway backend service → Variables tab:
#   1. DELETE the CLOUDINARY_URL variable if it contains placeholders like <your_api_key>
#   2. Add these three variables separately (recommended — secret may start with "-"):
#
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_numeric_api_key
# CLOUDINARY_API_SECRET=your_api_secret
#
# Do NOT commit real secrets to git. Set them only in Railway Variables.
#
# Avoid CLOUDINARY_URL when the secret starts with "-" — use the three variables above instead.
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@cloud_name

# Google Gemini — AI content + image generation. Get key: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Optional metadata (for your reference; not required by the API)
GEMINI_PROJECT_ID=

# Admin CMS token (set a long random string)
ADMIN_TOKEN=

# Admin login (email + password for /admin sign-in)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional: secret for on-demand ISR revalidation (defaults to ADMIN_TOKEN)
REVALIDATE_SECRET=

# Optional: OpenAI fallback for paraphrasing when Gemini is not set
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
