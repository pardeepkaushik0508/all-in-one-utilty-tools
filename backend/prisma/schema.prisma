generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Blog {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String        @db.Text
  featuredImage   String?
  author          String        @default("UtilityTools Team")
  readTime        String        @default("5 min")
  relatedToolSlug String?
  category        String?
  categoryId      String?
  blogCategory    BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  status          String        @default("draft")
  scheduledAt     DateTime?
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  keywords        Json?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  robotsIndex     Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tags            BlogTag[]

  @@index([status])
  @@index([categoryId])
  @@index([createdAt(sort: Desc)])
}

model BlogCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String   @default("")
  status      String   @default("active")
  isBuiltin   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blogs       Blog[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  blogs BlogTag[]
}

model BlogTag {
  blogId String
  tagId  String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
}

model CmsPage {
  id          String    @id
  slug        String    @unique
  title       String
  content     Json?
  sections    Json?
  seo         Json?
  status      String    @default("published")
  scheduledAt DateTime?
  revisions   Json?
  updatedAt   DateTime  @updatedAt
}

model ToolSeoContent {
  slug      String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model ToolSetting {
  slug                 String    @id
  toolName             String?
  enabled              Boolean   @default(true)
  featured             Boolean   @default(false)
  maintenanceMode      Boolean   @default(false)
  hiddenFromSearch     Boolean   @default(false)
  hiddenFromHomepage   Boolean   @default(false)
  hiddenFromNavigation Boolean   @default(false)
  order                Int       @default(0)
  scheduledEnableAt    DateTime?
  scheduledDisableAt   DateTime?
  maintenanceMessage   String?
  updatedAt            DateTime  @updatedAt
}

model NavigationConfig {
  id        String   @id @default("default")
  data      Json
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id         String   @id @default(cuid())
  filename   String
  storedName String?
  mimeType   String?
  size       Int?
  url        String?
  storage    String?
  localPath  String?
  createdAt  DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model SiteMeta {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
