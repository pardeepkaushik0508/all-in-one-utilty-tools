{
  "name": "all-in-one-utility-tools",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "bash scripts/dev-all.sh",
    "dev:ui": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "fuser -k 5000/tcp 2>/dev/null; npm run dev --workspace backend",
    "dev:clean": "CLEAN_NEXT=1 bash scripts/dev-all.sh",
    "dev:reset": "CLEAN_NEXT=1 bash scripts/dev-all.sh",
    "build": "npm run build --workspace frontend",
    "extract:extension-tools": "node scripts/extract-tools-metadata.js",
    "extension:icons": "node scripts/generate-extension-icons.js",
    "extension:build": "npm run extract:extension-tools && npm run extension:icons",
    "start": "bash scripts/start-frontend.sh",
    "start:frontend": "bash scripts/start-frontend.sh",
    "start:backend": "bash scripts/start-backend.sh"
  }
}
