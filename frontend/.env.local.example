NEXT_PUBLIC_SITE_URL=https://utilitytools.in

# Google Search Console — paste the content value from the HTML meta tag verification method
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Optional — only needed if NOT using Next.js proxy (default uses same-origin /api rewrite)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Used by next.config.js rewrites (server-side proxy to Express)
BACKEND_URL=http://127.0.0.1:5000
